---
/**
 * Reusable relative-comparison table.
 *
 * Given absolute measurements and a baseline row, each cell is shown as a
 * multiple of the baseline (computed per column: cell ÷ baseline-cell). 1.00× =
 * same; lower = "less" (here: faster / cheaper). Cells are color-coded
 * (green < 1, red > 1).
 *
 * Two interactions, both keyboard-accessible (real <button>s):
 *   - click a COLUMN header to sort by it (asc/desc; aria-sort on the <th>).
 *   - click a ROW label to re-base: that row becomes 1.00× and every cell is
 *     recomputed against it. Dividing a column by a different baseline preserves
 *     order, so re-basing never reflows or re-sorts — it only changes the
 *     displayed multiples and colors. Defaults to the `unit` row.
 *
 * It carries NO base table styling on purpose: it renders a plain <table>, so it
 * inherits the site's global table CSS (src/style/table.scss) and matches an
 * ordinary Markdown table. Pass `id` for per-instance overrides. It does no
 * measurement of its own — feed it numbers from your single source of truth.
 */
interface Column {
	key: string;
	label: string;
}
interface Row {
	label: string;
	cells: Record<string, number | null>;
}
interface Props {
	columns: Column[];
	rows: Row[];
	unit: string; // row label used as the initial 1.00× baseline (per column)
	caption?: string;
	sortKey?: string; // initial sort column key (default: first column)
	id?: string; // for per-instance CSS overrides
	rowHeader?: string; // header for the first column of row labels
}

const { columns, rows, unit, caption, sortKey, id, rowHeader = "" } = Astro.props as Props;

const baseRow = rows.find((r) => r.label === unit);
const ratioOf = (row: Row, key: string): number | null => {
	const base = baseRow?.cells[key];
	const v = row.cells[key];
	return v == null || base == null || base === 0 ? null : v / base;
};

const initialKey = sortKey ?? columns[0]?.key;
// Server-side initial sort by the column's ABSOLUTE value (same order as the
// ratio, and what the client sorts by); nulls last.
const sorted = [...rows].sort((a, b) => {
	const av = a.cells[initialKey];
	const bv = b.cells[initialKey];
	if (av == null && bv == null) return 0;
	if (av == null) return 1;
	if (bv == null) return -1;
	return av - bv;
});
// 1-based DOM column index of the initial sort column (column 0 is the label).
const initialCol = columns.findIndex((c) => c.key === initialKey) + 1;

const fmt = (r: number | null): string => {
	if (r == null) return "—";
	if (r === 1) return "1.00×";
	if (r >= 10) return `${Math.round(r)}×`;
	if (r >= 1) return `${r.toFixed(1)}×`;
	return `${r.toFixed(2)}×`;
};

// green (<1) → red (>1), intensity on a log scale so the wide range stays
// legible; baseline (=1) and missing cells stay uncolored.
const cellColor = (r: number | null): string => {
	if (r == null || r === 1) return "";
	const mag = Math.min(1, Math.abs(Math.log10(r)) / 1.6);
	const a = (0.12 + 0.4 * mag).toFixed(3);
	return r < 1 ? `rgba(80,170,110,${a})` : `rgba(210,80,80,${a})`;
};
const bgStyle = (r: number | null): string => {
	const c = cellColor(r);
	return c ? `background:${c}` : "";
};
---

<div
	class="table-wrapper"
	role="region"
	tabindex="0"
	aria-label="Table, scroll horizontally to see more"
>
	<table class="ratio-table" id={id} data-sortcol={String(initialCol)}>
		<thead>
			<tr>
				<th scope="col">{rowHeader}</th>
				{
					columns.map((c) => (
						<th scope="col" aria-sort={c.key === initialKey ? "ascending" : "none"}>
							<button
								type="button"
								class="ratio-table__sort"
								aria-label={`Sort by ${c.label}`}
							>
								{c.label}
								<span class="ratio-table__arrow" aria-hidden="true" />
							</button>
						</th>
					))
				}
			</tr>
		</thead>
		<tbody>
			{
				sorted.map((row) => {
					const isBase = row.label === unit;
					return (
						<tr class={isBase ? "ratio-table__unit" : undefined}>
							<td>
								<button
									type="button"
									class="ratio-table__pick"
									aria-pressed={isBase ? "true" : "false"}
									aria-label={`Use ${row.label} as the baseline`}
								>
									{row.label}
								</button>
							</td>
							{columns.map((c) => {
								const a = row.cells[c.key];
								const r = ratioOf(row, c.key);
								return (
									<td data-abs={a == null ? "" : String(a)} style={bgStyle(r)}>
										{fmt(r)}
									</td>
								);
							})}
						</tr>
					);
				})
			}
		</tbody>
	</table>
</div>
{caption && <p class="ratio-table__cap" set:html={caption} />}

<style>
	/* Only affordances on top of the global table look — no base table styling. */
	.ratio-table__sort,
	.ratio-table__pick {
		background: none;
		border: 0;
		padding: 0;
		margin: 0;
		font: inherit;
		color: inherit;
		cursor: pointer;
		text-align: inherit;
	}
	.ratio-table__sort {
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
	}
	.ratio-table__sort:hover,
	.ratio-table__pick:hover {
		text-decoration: underline;
	}
	.ratio-table__sort:focus-visible,
	.ratio-table__pick:focus-visible {
		outline: 2px solid currentColor;
		outline-offset: 2px;
	}
	/* the chosen baseline */
	.ratio-table__pick[aria-pressed="true"] {
		font-weight: 700;
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}
	/* Always-present, fixed-width arrow box → headers never reflow on re-sort. */
	.ratio-table__arrow {
		display: inline-block;
		width: 1.1em;
		text-align: center;
		font-size: 0.8em;
		opacity: 0.4;
	}
	.ratio-table__arrow::after {
		content: "⇅";
	}
	.ratio-table th[aria-sort="ascending"] .ratio-table__arrow,
	.ratio-table th[aria-sort="descending"] .ratio-table__arrow {
		opacity: 1;
	}
	.ratio-table th[aria-sort="ascending"] .ratio-table__arrow::after {
		content: "▲";
	}
	.ratio-table th[aria-sort="descending"] .ratio-table__arrow::after {
		content: "▼";
	}
	.ratio-table__unit {
		font-weight: 700;
	}
	.ratio-table__cap {
		font-size: 0.85rem;
		color: var(--text-color-alt);
		margin: -0.5em 0 1.5em;
	}
</style>

<script>
	const fmt = (r: number | null): string => {
		if (r == null) return "—";
		if (r === 1) return "1.00×";
		if (r >= 10) return `${Math.round(r)}×`;
		if (r >= 1) return `${r.toFixed(1)}×`;
		return `${r.toFixed(2)}×`;
	};
	const cellColor = (r: number | null): string => {
		if (r == null || r === 1) return "";
		const mag = Math.min(1, Math.abs(Math.log10(r)) / 1.6);
		const a = (0.12 + 0.4 * mag).toFixed(3);
		return r < 1 ? `rgba(80,170,110,${a})` : `rgba(210,80,80,${a})`;
	};
	const absOf = (cell: HTMLTableCellElement | undefined): number | null => {
		const v = cell?.dataset.abs;
		return v == null || v === "" ? null : parseFloat(v);
	};

	document.querySelectorAll<HTMLTableElement>(".ratio-table").forEach((table) => {
		const tbody = table.tBodies[0];
		if (!tbody) return;
		const ths = [...table.querySelectorAll<HTMLTableCellElement>("thead th")];
		const dataCols = ths.filter((th) => th.querySelector("button")).map((th) => th.cellIndex);
		let curCol = parseInt(table.dataset.sortcol || "1", 10);
		let asc = true;

		// --- sort by absolute value (order is invariant to the chosen baseline) ---
		const sortBy = (col: number, ascending: boolean) => {
			[...tbody.rows]
				.sort((a, b) => {
					const av = absOf(a.cells[col]);
					const bv = absOf(b.cells[col]);
					if (av == null && bv == null) return 0;
					if (av == null) return 1; // nulls last, both directions
					if (bv == null) return -1;
					return ascending ? av - bv : bv - av;
				})
				.forEach((r) => tbody.appendChild(r));
			ths.forEach((th) => {
				if (th.querySelector("button"))
					th.setAttribute(
						"aria-sort",
						th.cellIndex === col ? (ascending ? "ascending" : "descending") : "none",
					);
			});
		};
		ths.forEach((th) => {
			const btn = th.querySelector("button");
			if (!btn) return;
			btn.addEventListener("click", () => {
				if (th.cellIndex === curCol) asc = !asc;
				else {
					curCol = th.cellIndex;
					asc = true;
				}
				sortBy(curCol, asc);
			});
		});

		// --- re-base: clicked row becomes 1.00×, recompute multiples + colors ---
		const rebase = (baseRow: HTMLTableRowElement) => {
			const rowList = [...tbody.rows];
			dataCols.forEach((col) => {
				const base = absOf(baseRow.cells[col]);
				rowList.forEach((row) => {
					const cell = row.cells[col];
					if (!cell) return;
					const a = absOf(cell);
					const r = a == null || base == null || base === 0 ? null : a / base;
					cell.textContent = fmt(r);
					cell.style.background = cellColor(r);
				});
			});
			rowList.forEach((row) => {
				const pick = row.cells[0]?.querySelector("button");
				const isBase = row === baseRow;
				row.classList.toggle("ratio-table__unit", isBase);
				if (pick) pick.setAttribute("aria-pressed", isBase ? "true" : "false");
			});
		};
		tbody.querySelectorAll<HTMLButtonElement>(".ratio-table__pick").forEach((btn) => {
			btn.addEventListener("click", () => {
				const tr = btn.closest("tr");
				if (tr) rebase(tr as HTMLTableRowElement);
			});
		});
	});
</script>
