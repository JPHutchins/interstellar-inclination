---
interface Props {
	tags: string[];
	base?: string;
}

const { tags, base = "/?tag=" } = Astro.props;
---

{
	tags.length > 0 ? (
		<ul class="tags" aria-label="Tags">
			{tags.map((tag) => (
				<li>
					<a class="tag" href={`${base}${encodeURIComponent(tag)}`} data-tag={tag}>
						{tag}
					</a>
				</li>
			))}
		</ul>
	) : null
}

<style lang="scss">
	@use "../../style/pill" as *;

	.tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		padding: 0;
		margin: 0;

		li {
			margin: 0;
		}
	}

	.tag {
		@include pill;
		display: inline-block;
		padding: 0.35em 0.6em;
		text-decoration: none;
	}
</style>
