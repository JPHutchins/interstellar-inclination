---
interface Props {
	tags: string[];
	base?: string;
}

const { tags, base = "/?tag=" } = Astro.props;
---

{
	tags.length > 0 ? (
		<ul class="tags" aria-label="Tags">
			{tags.map((tag) => (
				<li>
					<a class="tag" href={`${base}${encodeURIComponent(tag)}`} data-tag={tag}>
						#{tag}
					</a>
				</li>
			))}
		</ul>
	) : null
}

<style>
	.tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		padding: 0;
		margin: 0;
	}

	.tag {
		display: inline-block;
		font-size: 0.8rem;
		line-height: 1;
		padding: 0.35em 0.6em;
		border-radius: 999px;
		border: 1px solid var(--text-color-link);
		color: var(--text-color-link);
		text-decoration: none;
		transition:
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.tag:hover,
	.tag:focus-visible {
		background-color: var(--text-color-link);
		color: var(--background-color);
	}
</style>
