---
interface Props {
	tags: string[];
}

const { tags } = Astro.props;
---

{
	tags.length > 0 ? (
		<div class="tag-filter" role="group" aria-label="Filter posts by tag">
			<button type="button" class="filter-pill is-active" data-tag="" aria-pressed="true">
				All
			</button>
			{tags.map((tag) => (
				<button type="button" class="filter-pill" data-tag={tag} aria-pressed="false">
					#{tag}
				</button>
			))}
		</div>
	) : null
}

<style>
	.tag-filter {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}

	.filter-pill {
		font-size: 0.85rem;
		line-height: 1;
		padding: 0.45em 0.7em;
		border-radius: 999px;
		border: 1px solid var(--text-color-link);
		background: transparent;
		color: var(--text-color-link);
		cursor: pointer;
		transition:
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.filter-pill:hover,
	.filter-pill:focus-visible {
		background-color: var(--text-color-link);
		color: var(--background-color);
	}

	.filter-pill.is-active {
		background-color: var(--text-color-link);
		color: var(--background-color);
		font-weight: bold;
	}
</style>
