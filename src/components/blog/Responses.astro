---
import Webmentions from "@components/blog/Webmentions";
import Giscus from "@components/blog/Giscus";
import { commentsConfig } from "@data/comments-config";

interface Props {
	postUrl: string;
}

const { postUrl } = Astro.props;
---

<section class="responses container" aria-label="Responses">
	<h2 class="responses-title">Responses</h2>
	<p class="responses-disclaimer">
		Responses are pulled in from the fediverse, Bluesky, and GitHub. I try to moderate them, but
		I can’t guarantee the content of other people’s replies. Expand to read them and join in.
	</p>

	<details class="responses-details">
		<summary class="responses-summary">
			<span class="responses-summary-show">Show responses</span>
			<span class="responses-summary-hide">Hide responses</span>
		</summary>

		<div class="responses-channels">
			<div class="responses-channel">
				<Webmentions postUrl={postUrl} />
			</div>

			<div class="responses-channel">
				<h3 class="responses-channel-title">Comment with GitHub</h3>
				<Giscus config={commentsConfig.giscus} />
			</div>
		</div>
	</details>
</section>
