---
import {
	responsesFor,
	contentHtml,
	contentText,
	authorName,
	responseLink,
	publishedAt,
	fediverseThreadFor,
} from "src/utils/webmentions";
import Date from "@components/utilities/Date";
import { sanitizeWebmentionHtml } from "src/utils/sanitize-webmention";
import { blueskyUrlFor } from "src/utils/bluesky-links";
import { commentsConfig } from "@data/comments-config";

interface Props {
	postUrl: string;
}

const { postUrl } = Astro.props;
const { replies, likes, reposts, count } = responsesFor(postUrl);
const blueskyThread = blueskyUrlFor(postUrl);
const fediverseThread = fediverseThreadFor(postUrl);

const fallbackAvatar = "/crumpledpaper_100x100.png";
const reactions = [...reposts, ...likes];

const hostOf = (url?: string): string => {
	if (!url) return "";
	try {
		return new URL(url).hostname;
	} catch {
		return "";
	}
};
---

<section class="webmentions" aria-label="Responses from the fediverse and Bluesky">
	<h3 class="webmentions-title">From the fediverse &amp; Bluesky</h3>

	{
		count === 0 ? (
			<p class="webmentions-empty">
				No responses yet. Reply from Mastodon, the wider fediverse, or Bluesky and it will
				appear here automatically (after a bit).
			</p>
		) : null
	}

	{
		reactions.length > 0 ? (
			<ul class="facepile" aria-label="Likes and reposts">
				{reactions.map((r) => {
					const verb = r["wm-property"] === "repost-of" ? "reposted" : "liked";
					const label = `${authorName(r)} ${verb} this`;
					return (
						<li>
							<a
								href={responseLink(r)}
								rel="nofollow ugc"
								aria-label={label}
								title={label}
							>
								<img
									src={r.author?.photo || fallbackAvatar}
									alt=""
									loading="lazy"
									width="40"
									height="40"
								/>
							</a>
						</li>
					);
				})}
			</ul>
		) : null
	}

	{
		replies.length > 0 ? (
			<ol class="webmention-list">
				{replies.map((reply) => {
					const html = contentHtml(reply);
					const text = contentText(reply);
					const link = responseLink(reply);
					const posted = publishedAt(reply);
					return (
						<li class="webmention">
							<div class="webmention-head">
								<a class="webmention-avatar" href={link} rel="nofollow ugc" aria-label={authorName(reply)}>
									<img
										src={reply.author?.photo || fallbackAvatar}
										alt=""
										loading="lazy"
										width="40"
										height="40"
									/>
									
								</a>
								<span class="webmention-byline">
									<a class="webmention-author" href={link} rel="nofollow ugc">
										<span class="webmention-author-name">{authorName(reply)}</span>
									</a>
									{link || posted ? (
										<span class="webmention-meta">
											{posted ? (
												<Date date={posted} time class="webmention-time" />
											) : null}
											{link ? (
												<a
													class="webmention-source"
													href={link}
													rel="nofollow ugc"
												>
													via {hostOf(link)}
												</a>
											) : null}
											
										</span>
									) : null}
								</span>
							</div>
							{html ? (
								<div
									class="webmention-body"
									set:html={sanitizeWebmentionHtml(html)}
								/>
							) : (
								<div class="webmention-body">
									<p>{text ?? ""}</p>
								</div>
							)}
							
						</li>
					);
				})}
			</ol>
		) : null
	}

	{
		fediverseThread ? (
			<p class="webmentions-discuss">
				<a href={fediverseThread} rel="nofollow ugc">
					Discuss this post on the fediverse →
				</a>
			</p>
		) : null
	}

	{
		blueskyThread ? (
			<p class="webmentions-discuss">
				<a href={blueskyThread}>Discuss this post on Bluesky →</a>
			</p>
		) : null
	}

	<p class="webmentions-cta">
		To join in, reply from your own account to
		<a href={commentsConfig.fediverseProfileUrl}>
			<code>{commentsConfig.fediverseHandle}</code>
		</a>
		on the fediverse, or
		<a href={commentsConfig.blueskyProfileUrl}>
			<code>{commentsConfig.blueskyHandle}</code>
		</a>
		on Bluesky.
	</p>
</section>

<script>
	const format = new Intl.DateTimeFormat(undefined, {
		year: "numeric",
		month: "long",
		day: "numeric",
		hour: "numeric",
		minute: "2-digit",
		timeZoneName: "short",
	});

	for (const el of document.querySelectorAll<HTMLTimeElement>(".webmention-time")) {
		const parsed = new Date(el.dateTime);
		if (!Number.isNaN(parsed.valueOf())) el.textContent = format.format(parsed);
	}
</script>
