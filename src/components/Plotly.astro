---
/**
 * Theme-aware Plotly chart for MDX posts.
 *
 * Usage in a `.mdx` post:
 *   import Plotly from "@components/Plotly";
 *   import { charts } from "@data/struct-charts";
 *   <Plotly {...charts.startup} caption="…" />
 *
 * The spec ({ data, layout }) is serialized into a data attribute and a single
 * bundled client script renders every chart on the page, applying the active
 * theme's colors (pulled from the CSS custom properties) and re-rendering when
 * the dark-mode toggle flips `data-theme`.
 */
interface Props {
	data: unknown[];
	layout?: Record<string, unknown>;
	caption?: string;
	height?: number;
}

const { data, layout = {}, caption, height = 440 } = Astro.props;
const spec = JSON.stringify({ data, layout });
---

<figure class="plotly-figure">
	<div class="plotly-chart" data-plotly={spec} style={`min-height:${height}px`}></div>
	{caption && <figcaption set:html={caption} />}
</figure>

<style>
	.plotly-figure {
		margin: 2rem 0;
	}
	.plotly-chart {
		width: 100%;
	}
	.plotly-figure figcaption {
		margin-top: 0.5rem;
		font-size: 0.85rem;
		color: var(--text-color-alt);
		text-align: center;
	}
</style>

<script>
	import Plotly from "plotly.js-dist-min";

	const cssVar = (name: string, fallback: string) =>
		getComputedStyle(document.documentElement).getPropertyValue(name).trim() || fallback;

	const themeLayout = () => {
		const text = cssVar("--text-color", "#3a4b4b");
		const dark = document.documentElement.getAttribute("data-theme") === "dark";
		const grid = dark ? "rgba(255,255,255,0.12)" : "rgba(0,0,0,0.10)";
		return {
			paper_bgcolor: "rgba(0,0,0,0)",
			plot_bgcolor: "rgba(0,0,0,0)",
			font: {
				color: text,
				family:
					"ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
			},
			xaxis: { gridcolor: grid, zerolinecolor: grid, fixedrange: true },
			yaxis: { gridcolor: grid, zerolinecolor: grid, fixedrange: true },
			legend: { bgcolor: "rgba(0,0,0,0)" },
			margin: { t: 48, r: 24, b: 56, l: 64 },
		};
	};

	// Deep-merge theme axis colors into each spec axis (incl. x2/y2…) without
	// clobbering the spec's own axis settings (type, tickvals, title…).
	const mergeTheme = (layout: Record<string, any>) => {
		const t = themeLayout() as Record<string, any>;
		const out: Record<string, any> = { ...t, ...layout };
		for (const key of Object.keys(out)) {
			if (/^[xy]axis\d*$/.test(key)) {
				out[key] = { ...t.xaxis, ...out[key] };
			}
		}
		out.font = { ...t.font, ...(layout.font ?? {}) };
		out.margin = { ...t.margin, ...(layout.margin ?? {}) };
		return out;
	};

	const render = (el: HTMLElement) => {
		const spec = JSON.parse(el.dataset.plotly!);
		Plotly.react(el, spec.data, mergeTheme(spec.layout ?? {}), {
			responsive: true,
			displayModeBar: false,
		});
	};

	const charts = Array.from(
		document.querySelectorAll<HTMLElement>(".plotly-chart[data-plotly]"),
	);
	if (charts.length) {
		charts.forEach(render);
		// Re-theme on dark-mode toggle.
		new MutationObserver(() => charts.forEach(render)).observe(document.documentElement, {
			attributes: true,
			attributeFilter: ["data-theme"],
		});
	}
</script>
